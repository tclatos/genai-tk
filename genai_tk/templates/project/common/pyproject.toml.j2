[project]
name = "{{ package_name }}"
version = "0.1.0"
description = "{{ project_name }} — built with genai-tk"
requires-python = ">=3.12,<3.13"
dependencies = [
    "genai-tk",
]

[dependency-groups]
dev = [
    "ruff>=0.11",
    "pytest>=8",
    "pytest-asyncio>=0.26",
]

[tool.uv]
package = true
default-groups = ["dev"]

[tool.ruff]
line-length = 120

[tool.ruff.lint]
select = ["E", "F", "I", "W"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
