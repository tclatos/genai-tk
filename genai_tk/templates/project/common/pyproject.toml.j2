[project]
name = "{{ package_name }}"
version = "0.1.0"
description = "{{ project_name }} — built with genai-tk"
requires-python = ">=3.12,<3.13"
dependencies = [
    "genai-tk",
]

# Forward genai-tk optional extras — install with: uv sync --extra <name>
[project.optional-dependencies]
harnessing = ["genai-tk[harnessing]"]
browser    = ["genai-tk[browser]"]
nlp        = ["genai-tk[nlp]"]
postgres   = ["genai-tk[postgres]"]
streamlit  = ["genai-tk[streamlit]"]
baml       = ["genai-tk[baml]"]
chromadb   = ["genai-tk[chromadb]"]

[dependency-groups]
dev = [
    "ruff>=0.11",
    "pytest>=8",
    "pytest-asyncio>=0.26",
]

[tool.uv]
package = true
default-groups = ["dev"]

[tool.ruff]
line-length = 120

[tool.ruff.lint]
select = ["E", "F", "I", "W"]

[tool.pytest.ini_options]
asyncio_mode = "auto"
testpaths = ["tests"]
